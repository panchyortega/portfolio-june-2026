<!DOCTYPE html>
<html lang="{{lang}}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Design System — Panchy Ortega</title>
  <link rel="preconnect" href="https://api.fontshare.com" />
  <link href="https://api.fontshare.com/v2/css?f[]=sora@400,500,600,700,800&f[]=work-sans@300,400,500,600,700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{cssPath}}styles/css/main.css" />
</head>
<body>

{{> nav}}

<div class="ds-layout">

  <div class="ds-header">
    <h1>Design System</h1>
    <p>Componentes, estilos y patrones del portafolio.</p>
  </div>

  {{! ── Componentes (auto-generados) ── }}
  {{#componentes}}
  <section class="ds-section" id="{{id}}">

    <div class="ds-section-header">
      <h2>{{titulo}}</h2>
      <span class="ds-badge">{{tipo}}</span>
    </div>
    <p class="ds-desc">{{descripcion}}</p>

    {{! Preview }}
    {{#muestra}}
    <div class="ds-preview">{{{muestra}}}</div>
    {{/muestra}}

    {{! Code block con tabs }}
    <div class="ds-code-block">
      <div class="ds-code-tabs">
        <button class="ds-tab active" data-target="mustache-{{id}}">Mustache</button>
        {{#has_less}}<button class="ds-tab" data-target="less-{{id}}">LESS</button>{{/has_less}}
      </div>
      <pre class="ds-code" id="mustache-{{id}}"><code>{{mustache_code}}</code></pre>
      {{#has_less}}<pre class="ds-code" id="less-{{id}}" hidden><code>{{less_code}}</code></pre>{{/has_less}}
    </div>

  </section>
  {{/componentes}}

  {{! ── Páginas ── }}
  {{#paginas}}
  <section class="ds-section" id="page-{{id}}">

    <div class="ds-section-header">
      <h2>{{titulo}}</h2>
      <span class="ds-badge">Página</span>
    </div>
    <p class="ds-desc">{{descripcion}}</p>

    {{! Esquema visual }}
    <div class="ds-page-schema">
      {{#es_3cols}}
      <div class="ds-schema-3col">
        <div class="ds-schema-full">Nav</div>
        {{#esquema}}
          {{#sidebar}}<div class="ds-schema-sidebar">{{label}}</div>{{/sidebar}}
          {{^sidebar}}<div class="ds-schema-main">{{label}}</div>{{/sidebar}}
        {{/esquema}}
      </div>
      {{/es_3cols}}
      {{^es_3cols}}
      <div class="ds-schema-simple">
        <div class="ds-schema-row">Nav</div>
        {{#esquema}}
        <div class="ds-schema-row">{{label}}</div>
        {{/esquema}}
      </div>
      {{/es_3cols}}
    </div>

    {{! Código del template }}
    <div class="ds-code-block">
      <div class="ds-code-tabs">
        <button class="ds-tab active" data-target="page-code-{{id}}">Template</button>
      </div>
      <pre class="ds-code" id="page-code-{{id}}"><code>{{template_code}}</code></pre>
    </div>

  </section>
  {{/paginas}}

</div>

{{> footer}}

<script>
// Tab switching
document.querySelectorAll('.ds-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    const block = tab.closest('.ds-code-block');
    const target = tab.dataset.target;

    // Deactivate all tabs and hide all code blocks in this block
    block.querySelectorAll('.ds-tab').forEach(t => t.classList.remove('active'));
    block.querySelectorAll('.ds-code').forEach(c => c.setAttribute('hidden', ''));

    // Activate clicked tab and show target code
    tab.classList.add('active');
    const targetEl = document.getElementById(target);
    if (targetEl) targetEl.removeAttribute('hidden');
  });
});
</script>

</body>
</html>
